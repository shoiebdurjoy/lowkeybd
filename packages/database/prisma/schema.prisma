generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  role          Role      @default(USER)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  profile       Profile?
  refreshTokens RefreshToken[]
  emailTokens   EmailVerificationToken[]

  posts         Post[]
  comments      Comment[]
  votes         Vote[]
  communities   CommunityMember[]

  notificationsReceived  Notification[]          @relation("UserNotifications")
  notificationsTriggered Notification[]          @relation("ActorNotifications")
  notificationPreference NotificationPreference?

  reports                Report[]                @relation("ReporterReports")
  assignedReports        Report[]                @relation("AssignedReports")
  moderationActions      ModerationAction[]      @relation("ModeratorActions")
  targetedActions        ModerationAction[]      @relation("TargetActions")
  auditLogs              AuditLog[]              @relation("AuditLogs")
  restrictions           UserRestriction[]       @relation("UserRestrictions")
  createdRestrictions    UserRestriction[]       @relation("CreatedRestrictions")
}

model Profile {
  id                String   @id @default(uuid())
  userId            String   @unique
  bio               String?
  avatarUrl         String?
  locationText      String?
  reputationScore   Int      @default(0)
  contributionCount Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  familyId  String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model Community {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  avatarUrl   String?
  bannerUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members     CommunityMember[]
  posts       Post[]
}

model CommunityMember {
  userId      String
  communityId String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  user        User       @relation(fields: [userId], references: [id])
  community   Community  @relation(fields: [communityId], references: [id])

  @@id([userId, communityId])
}

enum MemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum PostType {
  QUESTION
  DISCUSSION
  RECOMMENDATION
  GUIDE
  REVIEW
  WARNING
  NEWS_DISCUSSION
}

enum PostStatus {
  DRAFT
  PUBLISHED
  REMOVED
  LOCKED
}

model Post {
  id          String    @id @default(uuid())
  title       String
  content     String
  type        PostType  @default(DISCUSSION)
  slug        String?
  status      PostStatus @default(PUBLISHED)
  authorId    String
  communityId String?
  upvotes     Int       @default(0)
  downvotes   Int       @default(0)
  commentCount Int      @default(0)
  viewCount   Int       @default(0)
  score       Int       @default(0)
  publishedAt DateTime? @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  author      User       @relation(fields: [authorId], references: [id])
  community   Community? @relation(fields: [communityId], references: [id])
  comments    Comment[]
  votes       Vote[]

  @@index([authorId])
  @@index([communityId])
  @@index([type, status])
  @@index([score, createdAt])
}

model Comment {
  id         String    @id @default(uuid())
  content    String
  postId     String
  authorId   String
  parentId   String?
  score      Int       @default(0)
  replyCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  post      Post      @relation(fields: [postId], references: [id])
  author    User      @relation(fields: [authorId], references: [id])
  parent    Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentToComment")
  votes     Vote[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Vote {
  id        String   @id @default(uuid())
  value     Int      // 1 for upvote, -1 for downvote
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  post      Post?    @relation(fields: [postId], references: [id])
  comment   Comment? @relation(fields: [commentId], references: [id])

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

enum NotificationType {
  NEW_COMMENT
  NEW_REPLY
  MENTION
  MODERATION
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  actorId    String?
  type       NotificationType
  title      String
  body       String
  entityType String
  entityId   String
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user       User             @relation("UserNotifications", fields: [userId], references: [id])
  actor      User?            @relation("ActorNotifications", fields: [actorId], references: [id])

  @@index([userId, readAt, createdAt])
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  newCommentInApp Boolean  @default(true)
  newCommentEmail Boolean  @default(true)
  newReplyInApp   Boolean  @default(true)
  newReplyEmail   Boolean  @default(true)
  newMentionInApp Boolean  @default(true)
  newMentionEmail Boolean  @default(true)

  user            User     @relation(fields: [userId], references: [id])
}

// ---- Milestone 7: Moderation & Admin ----

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

model Report {
  id           String       @id @default(uuid())
  reporterId   String
  targetType   String       // "post", "comment", "user"
  targetId     String
  reason       String
  details      String?
  status       ReportStatus @default(PENDING)
  assignedToId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reporter     User         @relation("ReporterReports", fields: [reporterId], references: [id])
  assignedTo   User?        @relation("AssignedReports", fields: [assignedToId], references: [id])

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

model ModerationAction {
  id           String   @id @default(uuid())
  moderatorId  String
  targetUserId String?
  targetType   String
  targetId     String
  actionType   String   // "warn", "remove_content", "restrict", "ban", "unban"
  reason       String
  metadata     Json?
  createdAt    DateTime @default(now())

  moderator    User     @relation("ModeratorActions", fields: [moderatorId], references: [id])
  targetUser   User?    @relation("TargetActions", fields: [targetUserId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor      User?    @relation("AuditLogs", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model FeatureFlag {
  id                String   @id @default(uuid())
  key               String   @unique
  description       String?
  enabled           Boolean  @default(false)
  rolloutPercentage Int      @default(0)
  rules             Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UserRestriction {
  id          String    @id @default(uuid())
  userId      String
  type        String    // "ban", "mute", "post_restrict"
  reason      String
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation("UserRestrictions", fields: [userId], references: [id])
  createdBy   User      @relation("CreatedRestrictions", fields: [createdById], references: [id])

  @@index([userId, isActive])
}
