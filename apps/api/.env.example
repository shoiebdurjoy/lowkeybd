# ==========================================
# NestJS API Backend Environment Configuration Template
# ==========================================

# Environment mode (development, production, test)
NODE_ENV=development

# Server port
PORT=3001

# Database connection URL (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[db]?schema=public
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5433/lowkeybd?schema=public"

# Redis Cache and Rate Limiting connection URL
REDIS_URL="redis://127.0.0.1:6379"

# JWT Token Signing Secret (Required in production, fallback allowed in development)
JWT_SECRET=super-secret-key-for-dev

# Meilisearch Full-text Search service configuration
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=masterKey123!

# SMTP Configuration (Mailpit mock SMTP in dev)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

# Frontend URL (CORS allowed origins)
FRONTEND_URL=http://localhost:3000
